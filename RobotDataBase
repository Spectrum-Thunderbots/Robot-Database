        hardwareMap = opMode.hardwareMap;
        telemetry = opMode.telemetry;
        if (opMode instanceof LinearOpMode) linearOpMode = (LinearOpMode) opMode;
    }


    //method to be called to initialize all motors
    public void init() {
        flMotor = hardwareMap.get(DcMotor.class, "flMotor1");
        frMotor = hardwareMap.get(DcMotor.class, "flMotor2");
        blMotor = hardwareMap.get(DcMotor.class, "flMotor3");
        brMotor = hardwareMap.get(DcMotor.class, "flMotor4");

        Shooter = hardwareMap.get(DcMotorEx.class, "Shooter");

        linearslidemotor = hardwareMap.get(DcMotor.class, "linearslidemotor");
        claw = hardwareMap.get(Servo.class, "claw");
        wrist = hardwareMap.get(Servo.class, "wrist");

        flMotor.setDirection(DcMotor.Direction.FORWARD);
        frMotor.setDirection(DcMotor.Direction.REVERSE);
        blMotor.setDirection(DcMotor.Direction.FORWARD);
        brMotor.setDirection(DcMotor.Direction.REVERSE);

        /*
        use this to have all motors brake (resist motion) or float (slowly wind down) when you stop pressing the button
        flMotor.ZeroPowerBehavior;
        frMotor.ZeroPowerBehavior;
        blMotor.ZeroPowerBehavior;
        brMotor.ZeroPowerBehavior;
        */
    }

    //makes the response times of motors and servos more accurate and faster
    //P changes response time and F removes oscillation around wanted value (both small)
    //good values change but find a good up to speed (P) and the do F to stop oscillation
    public double PFTUNER(double wantedValue, double currentValue, double P, double F) {
        double error = wantedValue - currentValue;
        double errorfin = (P * error) + (F * wantedValue);
        return errorfin;
    }

    //method to set values to a max or min if greater than or less than
    private double rangeCheck(double value, double min, double max){
        if (value < min){
            value = min;
        } else if (value > max){
            value = max;
        }
        return value;
    }

    //movement code
    //have the wanted inputs on the joystick correspond to movement direction
    public void MechanumMoving(double forward, double sideways, double turn){
        double flpower = forward + sideways + turn;
        double frpower = forward - sideways - turn;
        double blpower = forward - sideways + turn;
        double brpower = forward + sideways - turn;

        rangeCheck(flpower, -1.0, 1.0);
        rangeCheck(frpower, -1.0, 1.0);
        rangeCheck(blpower, -1.0, 1.0);
        rangeCheck(brpower, -1.0, 1.0);

        flMotor.setPower(flpower);
        frMotor.setPower(frpower);
        blMotor.setPower(blpower);
        brMotor.setPower(brpower);
    }

    //displays drive motor values on driver station
    public void driveTelemetry(){
        String drive = String.format(Locale.US, "{FL: %.3f, FR: %.3f, BL: %.3f, BR: %.3f}", flMotor.getPower(), frMotor.getPower(), blMotor.getPower(), blMotor.getPower());
        telemetry.addData("Drive:", drive);
    }

    //have all values regardless of needed otherwise crash
    //controls linear slide and claw / wrist
    public void LinearSlideMovementUp(int input1,int claw1,int claw2){
        linearslidemotor.setPower(Math.abs(input1));
        claw.setPosition(Math.abs(claw1));
        wrist.setPosition(Math.abs(claw2));
    }
    //have all values regardless of needed otherwise crash
    //controls linear slide and claw / wrist
    public void LinearSlideMovementDown(int input1,int claw1,int claw2){
        linearslidemotor.setPower(-Math.abs(input1));
        claw.setPosition(-Math.abs(claw1));
        wrist.setPosition(-Math.abs(claw2));
    }

    //FLY method to be used to have fly wheel turn at wanted speed
    //change the active boolean to turn on and off and (if wanted) have a wanted speed
    //double at the top of the code to edit easier
    public void fly(boolean active){
        double currentSpeed = Shooter.getVelocity();
        double wantedSpeed = 0; //Your Speed Here

        double P = 0.000365; //change
        double F = 0.000424; //change

        double targetPower = PFTUNER(wantedSpeed, currentSpeed, P, F); //remove pf terms and just write values in method

        Shooter.setPower(targetPower);
    }

    //Boolean to be referenced by all programs
    public boolean REDAlliance;
    //put method in initialization to set the above global boolean
    //have a different button was pressed for each input
    public void setAlliance(boolean redInput, boolean blueInput){
        while (!(redInput || blueInput)) {} //waits until you do an input
        if (redInput == true) REDAlliance = true;
        else if (blueInput == true) REDAlliance = false;
    }

}


